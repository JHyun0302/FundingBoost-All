# 로컬(단일 VM) 통합 실행용 env 예시입니다.
# OCI 3-VM 배포는 아래 파일들을 사용하세요.
# - deploy/oci/env/edge.env.example
# - deploy/oci/env/front.env.example
# - deploy/oci/env/back.env.example
NGINX_PORT=80
CRAWLER_PORT=8090

MYSQL_ROOT_PASSWORD=1q2w3e4r!
MYSQL_DATABASE=fundingboost
MYSQL_USER=mysql
MYSQL_PASSWORD=1q2w3e4r!
CRAWLER_DB_NAME=item

FUNDINGBOOST_DB_URL=jdbc:mysql://mysql:3306/fundingboost?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
FUNDINGBOOST_DB_USERNAME=mysql
FUNDINGBOOST_DB_PASSWORD=1q2w3e4r!

CRAWLER_DB_URL=jdbc:mysql://mysql:3306/item?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
CRAWLER_DB_USERNAME=mysql
CRAWLER_DB_PASSWORD=1q2w3e4r!
# true면 컨테이너 시작 직후 브랜드/아이템 초기 적재를 자동 수행합니다.
CRAWLER_BOOTSTRAP_ENABLED=true
CRAWLER_BOOTSTRAP_ITEM_LIMIT=20
CRAWLER_INIT_API_ENABLED=true

REACT_APP_FUNDINGBOOST=/api/v1
REACT_APP_FUNDINGBOOST_V3=/api/v3

KAKAO_CLIENT_ID=dummy-client-id
KAKAO_CLIENT_SECRET=dummy-client-secret
KAKAO_REDIRECT_URI=http://localhost/login/oauth2/code/kakao
APP_ADMIN_EMAILS=qa1@fundingboost.test
FUNDINGBOOST_CORS_ORIGINS=http://localhost,http://localhost:80

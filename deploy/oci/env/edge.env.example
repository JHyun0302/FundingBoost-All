EDGE_HTTP_PORT=80

FRONT_PRIVATE_HOST=10.0.1.198
FRONT_PRIVATE_PORT=80
FRONT_OFFLOAD_ORIGIN=

BACK_PRIVATE_HOST=10.0.1.62
BACK_PRIVATE_PORT=8080

# Catalog API 라우팅 대상 (일반적으로 Back VM 내 crawler:8090)
CATALOG_PRIVATE_HOST=10.0.1.62
CATALOG_PRIVATE_PORT=8090
# Catalog 라우팅 모드: off | canary | full
CATALOG_ROUTE_MODE=off
# canary 모드에서 Catalog로 보낼 비율(정수, %)
CATALOG_CANARY_PERCENT=5

# Payment API 라우팅 대상 (일반적으로 Back VM 내 payment:8081)
PAYMENT_PRIVATE_HOST=10.0.1.62
PAYMENT_PRIVATE_PORT=8081
# Payment 라우팅 모드: off | canary | full
PAYMENT_ROUTE_MODE=off
# canary 모드에서 Payment 서비스로 보낼 비율(정수, %)
PAYMENT_CANARY_PERCENT=5

# 허용 Host 정규식 (예: 공인 IP + 도메인 + 로컬 점검)
EDGE_ALLOWED_HOST_REGEX=138[.]2[.]43[.]7|localhost|127[.]0[.]0[.]1
# 최초 1회 접근용 게이트 URL 경로 (반드시 랜덤 문자열로 변경)
EDGE_ENTRY_PATH=change-this-random-path
# 게이트 쿠키 유지 시간(초). 기본 30일
EDGE_ACCESS_COOKIE_MAX_AGE=2592000

# DoS/과도 트래픽 보호
EDGE_RATE_LIMIT_PER_IP=20r/s
EDGE_RATE_LIMIT_BURST=100
EDGE_CONN_LIMIT=30

TRAFFIC_THRESHOLD_TB=9
TRAFFIC_INTERFACE=
EDGE_CONTAINER_NAME=fundingboost-edge

# true면 컨테이너 시작 직후 브랜드/아이템 초기 적재를 자동 수행합니다.
CRAWLER_BOOTSTRAP_ENABLED=true
CRAWLER_BOOTSTRAP_ITEM_LIMIT=20
CRAWLER_INIT_API_ENABLED=true

KAKAO_CLIENT_ID=dummy-client-id
KAKAO_CLIENT_SECRET=dummy-client-secret
KAKAO_REDIRECT_URI=http://138.2.43.7/login/oauth2/code/kakao
# 바코드 검증 URL의 외부 노출 호스트(아이폰 QRbot 테스트 시 권장)
# 비우면 요청 Host를 자동 사용합니다.
APP_PAY_BARCODE_VERIFY_BASE_URL=http://138.2.43.7
FUNDINGBOOST_CORS_ORIGINS=http://138.2.43.7
# true면 item 스키마 준비 후 서버가 QA 테스트 계정/관계/북마크/펀딩 데이터를 1회 자동 생성합니다.
TESTDATA_BOOTSTRAP_ENABLED=true
TESTDATA_BOOTSTRAP_RETRY_DELAY_MS=10000

ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# Kafka (비동기 이벤트)
APP_KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HEAP_OPTS=-Xmx512m -Xms256m

# Catalog reader 전환 플래그
# local: 기존 DB 직접 조회
# remote: Catalog 서비스(funding-crawler) HTTP 조회
APP_CATALOG_READER=local
APP_CATALOG_REMOTE_BASE_URL=http://funding-crawler:8090
APP_CATALOG_REMOTE_FALLBACK_TO_LOCAL=true
APP_PAYMENT_FOLLOW_UP_MODE=direct
APP_PAYMENT_FOLLOW_UP_CONSUMERS_ENABLED=false
APP_PAYMENT_FOLLOW_UP_GROUP_ID=fundingboost-payment-follow-up
APP_PAYMENT_TOPICS_COMPLETED=fundingboost.payment.completed.v1
APP_PAYMENT_TOPICS_FAILED=fundingboost.payment.failed.v1
APP_INBOX_SCHEMA_BOOTSTRAP_ENABLED=true
APP_INBOX_CONSUMERS_ENABLED=false
APP_INBOX_GROUP_ID=fundingboost-domain-inbox
APP_INBOX_TOPICS_ORDER_PAID=fundingboost.commerce.order.paid.v1
APP_INBOX_TOPICS_FUNDING_CONTRIBUTION_CREATED=fundingboost.funding.contribution.created.v1
APP_INBOX_TOPICS_PAYMENT_FAILED=fundingboost.payment.failed.v1
APP_PAYMENT_PROXY_BASE_URL=http://fundingboost-server:8080
APP_PAYMENT_PROXY_CONNECT_TIMEOUT_MS=3000
APP_PAYMENT_PROXY_READ_TIMEOUT_MS=10000
APP_PAYMENT_CONSUMERS_ENABLED=false
APP_PAYMENT_CONSUMERS_GROUP_ID=fundingboost-payment-skeleton
